# MongoDB connection string
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/seatlock?retryWrites=true&w=majority

# JWT secret for signing auth tokens (pick something random and long)
JWT_SECRET=your_jwt_secret_here

# Port the server runs on
PORT=5000

# Stripe secret key (starts with sk_test_ or sk_live_)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Stripe webhook signing secret (starts with whsec_)
STRIPE_WEBHOOK_SECRET_KEY=whsec_your_webhook_secret

# Frontend origin for CORS (no trailing slash)
ORIGIN=http://localhost:4173
